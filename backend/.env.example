# NetGuardian backend environment examples

# Use a long random string in production.
AUTH_SECRET_KEY=replace-with-a-long-random-secret

# Access token expiration in seconds (default: 12h)
ACCESS_TOKEN_EXPIRE_SECONDS=43200

# Set this to enable admin registration.
# Example admin register code: NETGUARDIAN_ADMIN_2026
ADMIN_REGISTRATION_CODE=NETGUARDIAN_ADMIN_2026

# Optional: tune model decision thresholds.
# REVIEW_THRESHOLD: above this confidence and attack=true -> manual review.
# AUTO_BLOCK_THRESHOLD: above this confidence and attack=true -> auto block.
# REVIEW_THRESHOLD=0.82
# AUTO_BLOCK_THRESHOLD=0.90

# DeepSeek (OpenAI-style) chat settings
# DEEPSEEK_API_KEY=sk-xxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_SYSTEM_PROMPT=你是NetGuardian网络安全助手，优先中文回答，输出要简洁并给出处置步骤。
